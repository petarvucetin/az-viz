{
  "network vnet create": {
    "produces": { "kind": "vnet", "name_from": "--name" },
    "scope":    { "rg": "--resource-group", "location": "--location" },
    "refs":     [],
    "props":    { "cidr": "--address-prefixes" }
  },
  "network vnet subnet create": {
    "produces": { "kind": "subnet", "name_from": "--name" },
    "scope":    { "rg": "--resource-group" },
    "refs": [
      { "kind": "vnet", "via": "--vnet-name", "required": true }
    ],
    "props":    { "cidr": "--address-prefixes" }
  },
  "network nsg create": {
    "produces": { "kind": "nsg", "name_from": "--name" },
    "scope":    { "rg": "--resource-group", "location": "--location" },
    "refs":     []
  },
  "network nsg rule create": {
    "produces": { "kind": "nsg-rule", "name_from": "--name" },
    "scope":    { "rg": "--resource-group" },
    "refs": [
      { "kind": "nsg", "via": "--nsg-name", "required": true }
    ]
  },
  "network public-ip create": {
    "produces": { "kind": "public-ip", "name_from": "--name" },
    "scope":    { "rg": "--resource-group", "location": "--location" },
    "refs":     [],
    "props":    { "cidr": "--address", "sku": "--sku", "allocation": "--allocation-method" }
  },
  "network nic create": {
    "produces": { "kind": "nic", "name_from": "--name" },
    "scope":    { "rg": "--resource-group", "location": "--location" },
    "refs": [
      { "kind": "subnet",    "via": "--subnet",             "required": true },
      { "kind": "public-ip", "via": "--public-ip-address",  "required": false },
      { "kind": "nsg",       "via": "--network-security-group", "required": false }
    ]
  },
  "network route-table create": {
    "produces": { "kind": "route-table", "name_from": "--name" },
    "scope":    { "rg": "--resource-group", "location": "--location" },
    "refs":     []
  },
  "network vnet-gateway create": {
    "produces": { "kind": "vnet-gateway", "name_from": "--name" },
    "scope":    { "rg": "--resource-group", "location": "--location" },
    "refs": [
      { "kind": "vnet",      "via": "--vnet",                "required": true },
      { "kind": "public-ip", "via": "--public-ip-addresses", "required": true }
    ],
    "props": {
      "sku":          "--sku",
      "gateway-type": "--gateway-type",
      "vpn-type":     "--vpn-type"
    }
  },
  "network local-gateway create": {
    "produces": { "kind": "local-gateway", "name_from": "--name" },
    "scope":    { "rg": "--resource-group", "location": "--location" },
    "refs":     [],
    "props": {
      "cidr":       "--local-address-prefixes",
      "gateway-ip": "--gateway-ip-address"
    }
  },
  "network vpn-connection create": {
    "produces": { "kind": "vpn-connection", "name_from": "--name" },
    "scope":    { "rg": "--resource-group", "location": "--location" },
    "refs": [
      { "kind": "vnet-gateway",  "via": "--vnet-gateway1",  "required": true },
      { "kind": "local-gateway", "via": "--local-gateway2", "required": false },
      { "kind": "vnet-gateway",  "via": "--vnet-gateway2",  "required": false }
    ],
    "props": {
      "connection-type": "--connection-type"
    }
  }
}
